# ============================================================
# SmartFab Lathe — Backend Environment Variables
# Copy this file to .env and fill in every value before deploying.
# NEVER commit the real .env file to git.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# In Docker: use "db" as the host (the postgres service name)
# The password here must match POSTGRES_PASSWORD in the root .env
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@db:5432/smartfab

# ── Application ───────────────────────────────────────────────
# Set to "production" on the server — disables Swagger UI and SQL echo
APP_ENV=production

# ── JWT ───────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Frontend URL ──────────────────────────────────────────────
# The public URL users will reach your server on (no trailing slash).
# This must match NEXT_PUBLIC_API_URL in the root .env
# Examples: http://1.2.3.4   or   https://yourdomain.com
FRONTEND_URL=http://YOUR_EC2_PUBLIC_IP_OR_DOMAIN

# ── Bootstrap Admin ───────────────────────────────────────────
# Created automatically on first startup if no users exist yet.
# Change the password immediately after first login.
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeThisImmediately!
ADMIN_FULLNAME=Admin

# ── Gmail SMTP ────────────────────────────────────────────────
# Use a Gmail App Password (not your real password).
# Enable 2FA on the Gmail account, then create an App Password at:
# https://myaccount.google.com/apppasswords
SMTP_EMAIL=your-gmail@gmail.com
SMTP_APP_PASSWORD=xxxx xxxx xxxx xxxx
