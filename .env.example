# ============================================================
# Docker Compose — Root Environment Variables
# Copy this file to .env in the PROJECT ROOT and fill in values.
# docker-compose reads this file automatically.
# ============================================================

# ── PostgreSQL password ───────────────────────────────────────
# Must match the password in DATABASE_URL inside backend/.env
POSTGRES_PASSWORD=YOUR_SECURE_DB_PASSWORD

# ── Frontend API URL ──────────────────────────────────────────
# The public URL of your server — same value as FRONTEND_URL in backend/.env.
# This is baked into the Next.js JS bundle at build time.
# Examples: http://1.2.3.4   or   https://yourdomain.com
NEXT_PUBLIC_API_URL=http://YOUR_EC2_PUBLIC_IP_OR_DOMAIN
